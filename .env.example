# Filesystem path to the pickled model.
# Local default works as-is; in the container this is set to the
# in-container path via docker-compose.
MODEL_PATH=./model.pkl

# Minimum logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL).
LOG_LEVEL=INFO

# Format the logs are displayed in (only "json" and "console" are supported).
LOG_FORMAT=json
